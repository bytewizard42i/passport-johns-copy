# direnv configuration for DIDz.io local development
# Install direnv: https://direnv.net/docs/installation.html
# Then run: direnv allow

use node 22

# Point at your local compactc install if you have one.
# If unset, validate contracts via the Midnight MCP playground.
# export COMPACT_HOME=/opt/compact

# Default environment — override per shell if needed
export NODE_ENV=development
